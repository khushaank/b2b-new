Options -Indexes -MultiViews
DirectoryIndex index.html
ServerSignature Off

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Enforce HTTPS in production, including common reverse-proxy deployments.
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
  RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:\d+)?$ [NC]
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L,NE]

  # Direct visits to internal error documents return visitors to the public site.
  # Internal ErrorDocument subrequests keep their real HTTP status and error page.
  RewriteCond %{THE_REQUEST} \s/+((?:404|410|421|429|500|503)(?:\.html)?)(?:[?\s]) [NC]
  RewriteRule ^(?:404|410|421|429|500|503)(?:\.html)?$ / [R=302,L]

  # Redirect public .html URLs to their clean canonical form.
  RewriteCond %{THE_REQUEST} \s/+blog/index(?:\.html)?(?:[?\s]) [NC]
  RewriteRule ^blog/index(?:\.html)?$ /blog/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html(?:[?\s]) [NC]
  RewriteRule ^(.*/)?index\.html$ /$1 [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html(?:[?\s]) [NC]
  RewriteRule ^(.+)\.html$ /$1 [R=301,L,NE]

  # Internally serve the matching HTML document for clean URLs.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

ErrorDocument 404 /404
ErrorDocument 410 /410
ErrorDocument 421 /421
ErrorDocument 429 /429
ErrorDocument 500 /500
ErrorDocument 503 /503

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
  SetEnvIf Host "^(localhost|127\.0\.0\.1)(:[0-9]+)?$" local_preview
  Header always unset Content-Security-Policy
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://api.web3forms.com; script-src 'self'; script-src-elem 'self'; script-src-attr 'none'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data:; connect-src 'self' https://api.web3forms.com; manifest-src 'self'; worker-src 'self'"
  Header always unset X-Powered-By
  <If "%{HTTPS} == 'on'">
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  </If>

  <FilesMatch "\.(?:html?|json|xml|webmanifest)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(?:css|js)$">
    Header set Cache-Control "public, max-age=86400, stale-while-revalidate=3600"
  </FilesMatch>
  <FilesMatch "\.(?:webp|png|svg|woff2?)$">
    Header set Cache-Control "public, max-age=604800, stale-while-revalidate=86400"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType image/webp .webp
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/ld+json application/xml image/svg+xml
</IfModule>

# Keep build sources, repository metadata and server configuration private.
<FilesMatch "(^\.|README\.md$|package(?:-lock)?\.json$|.*\.(?:py|mjs)$)">
  Require all denied
</FilesMatch>
