Options -Indexes -MultiViews
AcceptPathInfo Off
DirectoryIndex index.html
ServerSignature Off

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTP_HOST} !^(?:b2bindustrial\.in|localhost|127\.0\.0\.1)(?::\d+)?$ [NC]
  RewriteRule ^ https://b2bindustrial.in%{REQUEST_URI} [R=301,L,NE]
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
  RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:\d+)?$ [NC]
  RewriteRule ^ https://b2bindustrial.in%{REQUEST_URI} [R=301,L,NE]

  RewriteCond %{REQUEST_URI} ^/$
  RewriteCond %{QUERY_STRING} ^(?:trk=|ref=|whoisdatacenter(?:_com|\.com))(?:[=&/]|$) [NC]
  RewriteRule ^$ / [R=301,L,NE,QSD]

  RewriteRule ^about-us(?:\.html)?/?$ /about [R=301,L,NE]
  RewriteRule ^vision-and-mission-statement(?:\.html)?/?$ /about [R=301,L,NE]
  RewriteRule ^contact-us(?:\.html)?/?$ /contact [R=301,L,NE]
  RewriteRule ^our_clients(?:\.html)?/?$ /clients [R=301,L,NE]
  RewriteRule ^terms-and-conditions(?:\.html)?/?$ /terms [R=301,L,NE]
  RewriteRule ^energy-audits(?:\.html)?/?$ /services/energy-audits [R=301,L,NE]
  RewriteRule ^electrical-engineering(?:\.html)?/?$ /services/electrical-projects [R=301,L,NE]
  RewriteRule ^emission-control(?:\.html)?/?$ /services/emission-control [R=301,L,NE]
  RewriteRule ^compliance(?:\.html)?/?$ /services/compliances [R=301,L,NE]
  RewriteRule ^hvac(?:\.html)?/?$ /services/hvac-projects [R=301,L,NE]
  RewriteRule ^hse-fire-safety(?:\.html)?/?$ /services/fire-life-safety [R=301,L,NE]
  RewriteRule ^repair-maintenance(?:\.html)?/?$ /services/repair-maintenance [R=301,L,NE]
  RewriteRule ^lighting-projects(?:\.html)?/?$ /services/lighting-projects [R=301,L,NE]
  RewriteRule ^services/energy-audit(?:\.html)?/?$ /services/energy-audits [R=301,L,NE]
  RewriteRule ^services/vesda(?:\.html)?/?$ /services/fire-detection [R=301,L,NE]
  RewriteRule ^services/hse-fire-safety(?:\.html)?/?$ /services/fire-life-safety [R=301,L,NE]
  RewriteRule ^services/fire-pump-testing(?:\.html)?/?$ /services/fire-compliance [R=301,L,NE]
  RewriteRule ^b2b-services/energy-audit-management(?:/index)?(?:\.html)?/?$ /services/energy-audits [R=301,L,NE]
  RewriteRule ^b2b-services/electrical-engineering(?:/index)?(?:\.html)?/?$ /services/electrical-projects [R=301,L,NE]
  RewriteRule ^b2b-services/emission-control-projects(?:/index)?(?:\.html)?/?$ /services/emission-control [R=301,L,NE]
  RewriteRule ^b2b-services/hvac(?:/index)?(?:\.html)?/?$ /services/hvac-projects [R=301,L,NE]
  RewriteRule ^b2b-services/fire-management(?:/index)?(?:\.html)?/?$ /services/fire-projects [R=301,L,NE]
  RewriteRule ^b2b-services/led-lights(?:/index)?(?:\.html)?/?$ /services/lighting-projects [R=301,L,NE]
  RewriteRule ^b2b-services/liasion-services-for-regulatory-compliances(?:/index)?(?:\.html)?/?$ /services/compliances [R=301,L,NE]
  RewriteRule ^b2b-services/other-value-added-services(?:/index)?(?:\.html)?/?$ /service [R=301,L,NE]
  RewriteRule ^blog-fire-safety-compliance-factory-act/?$ /blog/fire-safety-compliance-factory-act [R=301,L,NE]
  RewriteRule ^blog-cpcb-4-plus-dg-norms/?$ /blog/cpcb-4-plus-dg-norms [R=301,L,NE]
  RewriteCond %{QUERY_STRING} ^q= [NC]
  RewriteRule ^$ - [G,L]
  RewriteRule ^search/?$ - [G,L]

  RewriteRule ^servicess?/?$ /service [R=301,L,NE]
  RewriteRule ^services/index(?:\.html)?$ /service [R=301,L,NE]

  RewriteCond %{THE_REQUEST} \s/+(.+?)/(?:[?\s]) [NC]
  RewriteCond %{DOCUMENT_ROOT}/%1.html -f
  RewriteRule ^(.+)/$ /$1 [R=301,L,NE]

  RewriteRule ^favicon\.ico$ /favicon.png [R=301,L,NE]

  RewriteCond %{THE_REQUEST} \s/+((?:404|410|421|429|500|503)(?:\.html)?)(?:[?\s]) [NC]
  RewriteRule ^(?:404|410|421|429|500|503)(?:\.html)?$ / [R=302,L]

  RewriteCond %{THE_REQUEST} \s/+blog/index(?:\.html)?(?:[?\s]) [NC]
  RewriteRule ^blog/index(?:\.html)?$ /blog/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html(?:[?\s]) [NC]
  RewriteRule ^(.*/)?index\.html$ /$1 [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html(?:[?\s]) [NC]
  RewriteRule ^(.+)\.html$ /$1 [R=301,L,NE]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

ErrorDocument 404 /404
ErrorDocument 410 /410
ErrorDocument 421 /421
ErrorDocument 429 /429
ErrorDocument 500 /500
ErrorDocument 503 /503

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
  SetEnvIf Host "^(localhost|127\.0\.0\.1)(:[0-9]+)?$" local_preview
  Header always unset Content-Security-Policy
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://api.web3forms.com; script-src 'self'; script-src-elem 'self'; script-src-attr 'none'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data:; connect-src 'self' https://api.web3forms.com; manifest-src 'self'; worker-src 'none'"
  Header always unset X-Powered-By
  <If "%{HTTPS} == 'on'">
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  </If>

  <FilesMatch "\.(?:html?|json|xml|webmanifest)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(?:css|js)$">
    Header set Cache-Control "public, max-age=86400, stale-while-revalidate=3600"
  </FilesMatch>
  <FilesMatch "\.(?:webp|png|svg|woff2?)$">
    Header set Cache-Control "public, max-age=604800, stale-while-revalidate=86400"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType image/webp .webp
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/ld+json application/xml image/svg+xml
</IfModule>

<FilesMatch "(^\.|README\.md$|package(?:-lock)?\.json$|.*\.(?:py|mjs)$)">
  Require all denied
</FilesMatch>
